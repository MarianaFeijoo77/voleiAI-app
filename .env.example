# API
DATABASE_URL=postgresql://volei:volei@localhost:5432/voleidb
JWT_SECRET=your-secret-here-min-32-chars-long
PORT=3001

# Cloudflare R2
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=volei-videos

# Redis
REDIS_URL=redis://localhost:6379

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Modal.com (CV Pipeline)
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=your-mp-token
MERCADOPAGO_WEBHOOK_SECRET=your-mp-webhook-secret

# Stripe (secondary, international)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# App URLs
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000

# CV Pipeline (set via Modal secrets in production)
# R2_ENDPOINT, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_BUCKET

# Optional
# YOUTUBE_API_KEY=  # For training data collection
# SENTRY_DSN=       # For error tracking
